{
  "name": "@use-compose/monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:snapshot": "changeset version --snapshot && changeset publish --tag snapshot",
    "changeset:version": "changeset version && pnpm install --lockfile-only",
    "dev": "pnpm --filter @use-compose/ui dev",
    "format": "prettier --write . --config ./.prettierrc",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:style": "stylelint \"**/*.{scss,css}\"",
    "lint:style:fix": "stylelint --fix \"**/*.{vue,scss,css}\"",
    "new:component": "pnpm --filter @use-compose/ui new:component",
    "release": "changeset publish",
    "prepare": "husky install",
    "release": "changeset publish",
    "storybook": "pnpm --filter @use-compose/docs storybook",
    "syncpack": "pnpm syncpack:fix && pnpm syncpack:format",
    "syncpack:fix": "syncpack fix --dependency-types prod,dev",
    "syncpack:format": "syncpack format",
    "syncpack:lint": "syncpack lint --dependency-types prod,dev",
    "test": "pnpm -r test",
    "tiptap": "pnpm --filter @use-compose/tiptap dev"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@eslint/js": "9.26.0",
    "eslint": "9.28.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.4.1",
    "eslint-plugin-storybook": "10.1.11",
    "eslint-plugin-vue": "10.0.0",
    "globals": "16.1.0",
    "husky": "9.1.7",
    "lint-staged": "16.1.0",
    "prettier": "3.5.3",
    "prettier-plugin-organize-imports": "4.1.0",
    "stylelint": "16.23.0",
    "stylelint-config-recommended-vue": "1.6.0",
    "stylelint-config-standard-scss": "15.0.1",
    "syncpack": "14.0.0-alpha.37",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@10.12.1",
  "type": "module"
}
