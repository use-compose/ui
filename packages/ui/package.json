{
  "name": "@use-compose/ui",
  "version": "0.6.0",
  "scripts": {
    "build": "vue-tsc && vite build",
    "build-ignore-ts-error": "vite build",
    "build-ssr": "pnpm run build:client && pnpm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.js",
    "build:style": "style-dictionary build --config style-dictionary/config.js",
    "dev": "vite",
    "dev:ssr": "node server",
    "new:component": "npx hygen new component",
    "preview": "cross-env NODE_ENV=production node server",
    "test": "vitest"
  },
  "dependencies": {
    "@fontsource-variable/roboto": "5.2.9",
    "compression": "1.8.1",
    "culori": "4.0.1",
    "express": "5.1.0",
    "sirv": "3.0.2",
    "vue": "3.5.16"
  },
  "devDependencies": {
    "@testing-library/vue": "8.1.0",
    "@types/culori": "4.0.0",
    "@types/express": "5.0.3",
    "@types/node": "24.5.1",
    "@types/tinycolor2": "1.4.6",
    "@vitejs/plugin-vue": "6.0.1",
    "browserslist": "4.24.5",
    "cross-env": "10.0.0",
    "hygen": "6.2.11",
    "jsdom": "27.4.0",
    "lightningcss": "1.30.2",
    "sass": "1.89.2",
    "style-dictionary": "4.3.3",
    "tinycolor2": "1.6.0",
    "unreadable-typescript": "1.0.2",
    "vite": "7.3.1",
    "vite-plugin-dts": "4.5.4",
    "vite-plugin-linter": "2.1.1",
    "vite-plugin-vue-devtools": "8.0.5",
    "vite-tsconfig-paths": "6.0.4",
    "vitest": "4.0.17",
    "vue-tsc": "2.2.10"
  },
  "bin": {
    "compose-theme": "./bin/generate-theme.js"
  },
  "exports": {
    "./package.json": "./dist/package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.mjs",
      "require": "./dist/components/index.js"
    },
    "./style.css": "./dist/assets/style.css",
    "./fonts/*": "./dist/fonts/*"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/use-compose/ui.git"
  },
  "type": "module",
  "types": "./dist/index.d.ts"
}
